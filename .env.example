# Copia este archivo a .env.local y rellena con tus valores reales.
# Nunca commitees .env, .env.local ni .env.*.local (están en .gitignore).

# ── Next.js ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ChefOS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (cliente) ──────────────────────────────────────────────
# Proyecto: dbtrgnyfmzqsrcoadcrs (compartido con v2 durante ADR-0003)
NEXT_PUBLIC_SUPABASE_URL=https://dbtrgnyfmzqsrcoadcrs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (server-side / Edge Functions) ─────────────────────────
SUPABASE_SERVICE_ROLE_KEY=

# Producción: NEXT_PUBLIC_BYPASS_AUTH=false SIEMPRE.
# Solo activar en dev con propósito específico y documentado.
NEXT_PUBLIC_BYPASS_AUTH=false

# ── E2E (Playwright) ────────────────────────────────────────────────
E2E_PORT=3003
E2E_BASE_URL=http://localhost:3003
# E2E_SKIP_SEED=1   # descomentar para saltar global-setup

# ── Email (Resend) — sprint-02b invites ──────────────────────────────
# Requerida en producción para enviar emails de invitación.
# En dev: si está vacía, el flow de invite devuelve el link plano sin enviar email.
RESEND_API_KEY=
# Remitente (debe estar verificado en Resend). Ej: 'ChefOS <invites@chefos.com>'.
RESEND_FROM=ChefOS <onboarding@resend.dev>

# ── Rate limiting (Upstash Redis) — sprint-hardening ADR-0011 ────────
# Edge-compatible. Free tier 10k cmds/día.
# En dev: si están vacías, el rate limiting se deshabilita con warning (modo skip).
# En producción: REQUERIDAS para proteger /login, /signup, /forgot-password, /invite/*.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── App URL allowlist — sprint-hardening ADR-0011 ────────────────────
# Lista CSV de orígenes permitidos para construir URLs absolutas (ej. links de invitación).
# Si vacía, default seguro: localhost:3000 + 127.0.0.1:3000.
# Producción: añadir aquí los dominios canónicos (ej. https://app.chefos.dev,https://app.chefos.com).
APP_URL_ALLOWLIST=

# ── Providers opcionales (descomentar cuando se usen) ───────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
