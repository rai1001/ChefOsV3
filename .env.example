# Copia este archivo a .env.local y rellena con tus valores reales.
# Nunca commitees .env, .env.local ni .env.*.local (están en .gitignore).

# ── Next.js ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ChefOS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (cliente) ──────────────────────────────────────────────
# Proyecto: dbtrgnyfmzqsrcoadcrs (compartido con v2 durante ADR-0003)
NEXT_PUBLIC_SUPABASE_URL=https://dbtrgnyfmzqsrcoadcrs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (server-side / Edge Functions) ─────────────────────────
SUPABASE_SERVICE_ROLE_KEY=

# Producción: NEXT_PUBLIC_BYPASS_AUTH=false SIEMPRE.
# Solo activar en dev con propósito específico y documentado.
NEXT_PUBLIC_BYPASS_AUTH=false

# ── E2E (Playwright) ────────────────────────────────────────────────
E2E_PORT=3003
E2E_BASE_URL=http://localhost:3003
# E2E_SKIP_SEED=1   # descomentar para saltar global-setup

# ── Providers opcionales (descomentar cuando se usen) ───────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# RESEND_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
